rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Konfigurace (claudeKey apod.) — čtení jen přihlášení, zápis nikdo přes klienta
    match /config/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Uživatelská data — jen vlastník má přístup
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rodinná skupina — hlavní dokument
    match /families/{familyId} {
      // Čtení: každý přihlášený (potřebné pro join-by-code)
      allow read: if request.auth != null;
      // Vytvoření: přihlášený uživatel, který je v members
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;
      // Aktualizace: stávající člen NEBO nový člen přidávající sebe
      allow update: if request.auth != null && (
        request.auth.uid in resource.data.members ||
        request.auth.uid in request.resource.data.members
      );
      allow delete: if false;
    }

    // Rodinné podkomunity (shopItems, events, meals…) — jen členové skupiny
    match /families/{familyId}/{subcollection}/{docId} {
      allow read, write: if request.auth != null
        && exists(/databases/$(database)/documents/families/$(familyId))
        && request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
    }
  }
}
